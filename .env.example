# =============================================
# KING STORE - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Supabase - Connection Pooling (use for app queries via Prisma)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase - Direct Connection (use for Prisma migrations)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# JWT Secret - use a random string of at least 32 chars
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# App URL
NEXTAUTH_URL="http://localhost:3000"

# Supabase Public Keys (optional - for future Supabase client use)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
